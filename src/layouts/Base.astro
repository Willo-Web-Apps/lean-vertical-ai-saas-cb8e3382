---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fieldwright — Your HVAC business, running itself.",
  description = "Fieldwright is the AI operating system for small HVAC companies. Automate lead qualification, estimate drafting, scheduling, and invoicing — without replacing your existing tools."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Fieldwright",
      "description": "AI operating system for small HVAC companies. Automates lead qualification, estimate drafting, scheduling, invoicing, and owner reporting.",
      "url": "https://fieldwright.io"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
